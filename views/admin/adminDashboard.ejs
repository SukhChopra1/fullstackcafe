<link rel="stylesheet" href="/css/admin.css">

<div class="container">
    <div class="dashboard-header">
        <div>
            <h1>Cafe Control Hub <span class="pulse-dot"></span></h1>
            <p>Admin Dashboard</p>
        </div>
        <a href="/admin/add-product" class="add-product-btn">+ Add Product</a>
    </div>

    <div class="stats-grid" id="stats-container">
        <div class="order-card"><h3>₹<%= stats.totalRevenue %></h3><p>Revenue</p></div>
        <div class="order-card"><h3><%= stats.activeOrders %></h3><p>Active Orders</p></div>
        <div class="order-card"><h3><%= stats.orderCount %></h3><p>Total Orders</p></div>
    </div>

    <div class="tabs">
        <div class="tab active" onclick="switchTab('orders-section', event)">Live Orders</div>
        <div class="tab" onclick="switchTab('menu-section', event)">Manage Menu</div>
    </div>

    <div id="orders-section" class="tab-content active">
        <div class="order-card">
            <table>
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="orders-list">
                    <% orders.forEach(order => { %>
                    <tr id="order-row-<%= order._id %>">
                        <td>#<%= order._id.toString().slice(-6) %></td>
                        <td>
                            <strong><%= order.user ? order.user.username : 'Guest' %></strong><br>
                            <small><%= order.user ? order.user.email : '' %></small>
                        </td>
                        <td>₹<%= order.totalAmount %></td>
                        <td>
                            <span class="status-badge" id="order-status-<%= order._id %>">
                                <%= order.status %>
                            </span>
                        </td>
                        <td>
                            <select onchange="updateOrderStatus('<%= order._id %>', this.value)">
                                <option value="Pending" <%= order.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                                <option value="Preparing" <%= order.status === 'Preparing' ? 'selected' : '' %>>Preparing</option>
                                <option value="Out for Delivery" <%= order.status === 'Out for Delivery' ? 'selected' : '' %>>Out for Delivery</option>
                                <option value="Delivered" <%= order.status === 'Delivered' ? 'selected' : '' %>>Delivered</option>
                            </select>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <div id="menu-section" class="tab-content">
        <div class="order-card">
            <table>
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Current Stock</th>
                        <th>Update Qty</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(product => { %>
                    <tr id="row-<%= product._id %>">
                        <td><strong><%= product.name %></strong></td>
                        <td>₹<%= product.price %></td>
                        <td>
                            <input type="number" 
                                   id="stock-val-<%= product._id %>" 
                                   class="stock-input" 
                                   value="<%= product.stock %>" 
                                   min="0">
                        </td>
                        <td>
                            <button class="update-stock-btn" onclick="updateStock('<%= product._id %>')">
                                💾 Save
                            </button>
                        </td>
                        <td>
                            <span id="badge-<%= product._id %>" 
                                  class="status-badge <%= product.stock > 0 ? 'status-available':'status-soldout' %>">
                                <%= product.stock > 0 ? 'Available':'Sold Out' %>
                            </span>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="toast-container"></div>

<script>
/* --- TAB SWITCHING LOGIC --- */
function switchTab(sectionId, event) {
    document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(tab => tab.classList.remove('active'));
    document.getElementById(sectionId).classList.add('active');
    event.currentTarget.classList.add('active');
}

/* --- NOTIFICATION LOGIC --- */
function showNotification(message, type = 'success') {
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    toast.innerText = message;
    container.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
}

/* --- NEW: AUTO-REFRESH DATA FETCHING --- */
async function fetchDashboardData() {
    try {
        const response = await fetch('/admin/dashboard-data');
        const data = await response.json();

        if (data.success) {
            // Update Stats
            document.getElementById('stats-container').innerHTML = `
                <div class="order-card"><h3>₹${data.stats.totalRevenue}</h3><p>Revenue</p></div>
                <div class="order-card"><h3>${data.stats.activeOrders}</h3><p>Active Orders</p></div>
                <div class="order-card"><h3>${data.stats.orderCount}</h3><p>Total Orders</p></div>
            `;

            // Update Orders List
            const ordersList = document.getElementById('orders-list');
            ordersList.innerHTML = data.orders.map(order => `
                <tr id="order-row-${order._id}">
                    <td>#${order._id.toString().slice(-6)}</td>
                    <td>
                        <strong>${order.user ? order.user.username : 'Guest'}</strong><br>
                        <small>${order.user ? order.user.email : ''}</small>
                    </td>
                    <td>₹${order.totalAmount}</td>
                    <td><span class="status-badge" id="order-status-${order._id}">${order.status}</span></td>
                    <td>
                        <select onchange="updateOrderStatus('${order._id}', this.value)">
                            <option value="Pending" ${order.status === 'Pending' ? 'selected' : ''}>Pending</option>
                            <option value="Preparing" ${order.status === 'Preparing' ? 'selected' : ''}>Preparing</option>
                            <option value="Out for Delivery" ${order.status === 'Out for Delivery' ? 'selected' : ''}>Out for Delivery</option>
                            <option value="Delivered" ${order.status === 'Delivered' ? 'selected' : ''}>Delivered</option>
                        </select>
                    </td>
                </tr>
            `).join('');
        }
    } catch (err) {
        console.error("Auto-refresh error:", err);
    }
}

// Automatically refresh every 30 seconds
setInterval(fetchDashboardData, 30000);

/* --- UPDATE STOCK --- */
function updateStock(productId) {
    const newStock = document.getElementById(`stock-val-${productId}`).value;

    fetch(`/admin/update-stock/${productId}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ stock: newStock })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            showNotification(`Stock updated!`);
            const badge = document.getElementById(`badge-${productId}`);
            if (parseInt(newStock) > 0) {
                badge.className = "status-badge status-available";
                badge.innerText = "Available";
            } else {
                badge.className = "status-badge status-soldout";
                badge.innerText = "Sold Out";
            }
        }
    });
}

/* --- UPDATE ORDER STATUS --- */
function updateOrderStatus(orderId, newStatus) {
    fetch(`/admin/update-order-status/${orderId}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ status: newStatus })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            showNotification("Status updated!");
            document.getElementById(`order-status-${orderId}`).innerText = newStatus;
            // Immediate stats refresh after manual update
            fetchDashboardData();
        }
    });
}
</script>