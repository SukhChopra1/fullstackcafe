<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - FullStack Cafe</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        /* ================= RESET & BASE ================= */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            min-height: 100vh;
            /* Light, warm café-inspired background */
            background: #fdfcfb; 
            background-image: linear-gradient(120deg, #fdfbfb 0%, #ebedee 100%);
            display: flex;
            flex-direction: column;
            color: #333;
        }
/* ================= FORCE HEADER VISIBILITY ================= */
header {
    width: 100%;
    background: #ffffff !important; /* Force solid white */
    border-bottom: 1px solid #e2e8f0 !important; /* Light gray bottom border */
    padding: 15px 0 !important;
    position: relative;
    z-index: 1000;
}

/* Target the Logo */
header a, 
header .logo, 
header .brand-name {
    color: #4a3728 !important; /* Deep Coffee Brown */
    text-decoration: none !important;
    font-weight: 700 !important;
}

/* Target all Navigation Links (Menu, Login, Signup) */
header .nav-link, 
header nav a, 
header ul li a {
    color: #2d3748 !important; /* Dark Slate Gray */
    font-weight: 500 !important;
    text-decoration: none !important;
    margin: 0 15px !important;
    transition: color 0.2s !important;
}

header .nav-link:hover, 
header nav a:hover {
    color: #d4a373 !important; /* Tan/Latte color on hover */
}

/* Target the Cart text and Icon */
header .cart-link, 
header .cart-icon,
header #cart-count {
    color: #2d3748 !important;
}

/* If you have a user profile name showing */
header .user-name {
    color: #4a3728 !important;
    font-weight: 600 !important;
}
        /* ================= CENTER CONTAINER ================= */
        .login-wrapper {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
        }

        /* ================= LOGIN CARD (LIGHT) ================= */
        .form-box {
            width: 100%;
            max-width: 420px;
            padding: 40px;
            border-radius: 20px;
            background: #ffffff;
            border: 1px solid #eee;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
            text-align: center;
            animation: fadeIn 0.6s ease-out;
        }

        .form-box h2 {
            color: #4a3728; /* Coffee Brown */
            margin-bottom: 8px;
            font-size: 30px;
            font-weight: 700;
        }

        .form-box p.subtitle {
            color: #8c7e74;
            margin-bottom: 30px;
            font-size: 14px;
        }

        /* ================= NOTIFICATION BOX ================= */
        .msg {
            padding: 12px;
            border-radius: 10px;
            font-size: 14px;
            margin-bottom: 20px;
            display: none; 
            font-weight: 500;
        }

        .msg.error {
            display: block;
            background: #fff5f5;
            color: #c53030;
            border: 1px solid #feb2b2;
            animation: shake 0.5s ease;
        }

        /* ================= FORM ELEMENTS ================= */
        .form-group {
            margin-bottom: 18px;
        }

        .form-box input {
            width: 100%;
            padding: 14px 18px;
            border: 2px solid #edf2f7;
            border-radius: 12px;
            outline: none;
            font-size: 15px;
            background: #f8fafc;
            color: #2d3748;
            transition: all 0.3s ease;
        }

        .form-box input:focus {
            border-color: #d4a373; /* Warm Latte Accent */
            background: #fff;
            box-shadow: 0 0 0 4px rgba(212, 163, 115, 0.1);
        }

        /* ================= BUTTON ================= */
        .form-box button {
            width: 100%;
            padding: 14px;
            margin-top: 10px;
            border: none;
            border-radius: 12px;
            background: #4a3728; /* Solid Coffee Brown */
            color: #ffffff;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .form-box button:hover {
            background: #5d4636;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(74, 55, 40, 0.2);
        }

        .form-box button:disabled {
            background: #a89a8e;
            cursor: not-allowed;
        }

        /* ================= FOOTER LINKS ================= */
        .footer-links {
            margin-top: 25px;
            color: #718096;
            font-size: 14px;
        }

        .form-box a {
            color: #d4a373;
            text-decoration: none;
            font-weight: 600;
        }

        .form-box a:hover {
            text-decoration: underline;
        }

        /* ================= ANIMATIONS ================= */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }
    </style>
</head>
<body>

    <header>
        <%- include('partials/header') %>
    </header>

    <div class="login-wrapper">
        <div class="form-box">
            <h2>Welcome Back</h2>
            <p class="subtitle">Log in to your FullStack Cafe account</p>
            
            <div id="message-container" class="msg"></div>

            <form id="loginForm">
                <div class="form-group">
                    <input type="email" name="email" placeholder="Email Address" required>
                </div>
                
                <div class="form-group">
                    <input type="password" name="password" placeholder="Password" required>
                </div>
                
                <button type="submit" id="submitBtn">Login to Account</button>
            </form>

            <div class="footer-links">
                Don't have an account? <a href="/signup">Sign Up</a>
            </div>
        </div>
    </div>

    <script>
        const loginForm = document.getElementById('loginForm');
        const msgDiv = document.getElementById('message-container');
        const submitBtn = document.getElementById('submitBtn');

        loginForm.addEventListener('submit', async (e) => {
            e.preventDefault(); 

            // Disable button during request
            submitBtn.innerText = "Checking...";
            submitBtn.disabled = true;

            // Reset error messages
            msgDiv.style.display = 'none';
            msgDiv.innerText = '';
            msgDiv.classList.remove('error');

            const formData = new FormData(loginForm);
            const data = Object.fromEntries(formData.entries());

            try {
                const response = await fetch('/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    window.location.href = result.redirectUrl || '/products';
                } else {
                    // Stay on page and show notification
                    msgDiv.innerHTML = `${result.message || "Invalid credentials"}`;

                    if (result.isUnverified && result.verifyUrl) {
                        msgDiv.innerHTML += `<br><a href="${result.verifyUrl}" style="color: #2f855a; font-weight: 700;">Verify your account now</a>`;
                    }

                    msgDiv.style.display = 'block';
                    msgDiv.classList.add('error');
                    
                    // Re-enable button
                    submitBtn.innerText = "Login to Account";
                    submitBtn.disabled = false;
                }
            } catch (err) {
                msgDiv.innerText = "Something went wrong. Please try again.";
                msgDiv.style.display = 'block';
                msgDiv.classList.add('error');
                submitBtn.innerText = "Login to Account";
                submitBtn.disabled = false;
            }
        });

        // Check for success messages in URL (e.g., from verify-otp)
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('message')) {
            msgDiv.innerText = urlParams.get('message');
            msgDiv.style.display = 'block';
            msgDiv.style.background = "#f0fff4";
            msgDiv.style.color = "#2f855a";
            msgDiv.style.border = "1px solid #c6f6d5";
            window.history.replaceState({}, document.title, window.location.pathname);
        }
    </script>

</body>
</html>